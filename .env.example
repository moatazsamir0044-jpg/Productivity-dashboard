# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase (safe to expose to the browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Anthropic (server-side only — never expose to the client)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the planning model (defaults to claude-sonnet-5)
# CLAUDE_MODEL=claude-sonnet-5

# ---------------------------------------------------------------------------
# Supabase Auth configuration (done in the Supabase dashboard, not here)
# ---------------------------------------------------------------------------
# Email confirmation links and post-login redirects use the project's
# Site URL, which defaults to http://localhost:3000. When the app is
# deployed, that default sends confirmation links to localhost and they
# fail to open. In the Supabase dashboard:
#
#   Authentication -> URL Configuration
#     Site URL:       https://YOUR-DEPLOYMENT.vercel.app
#     Redirect URLs:  https://YOUR-DEPLOYMENT.vercel.app/**
#                     http://localhost:3000/**   (keep for local dev)
#
# For a single-user dashboard you may also disable the email step entirely:
#   Authentication -> Providers -> Email -> turn off "Confirm email"
# With confirmation off, sign-up creates a session immediately and the app
# redirects straight to /dashboard (see lib/auth/actions.ts).
